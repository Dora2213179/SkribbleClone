    "@prisma/client": "^5.21.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "prisma": "^5.21.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
